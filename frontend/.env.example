# Public frontend API base URL. Do not put secrets in VITE_* variables.
VITE_GARGOYLE_API_BASE_URL=/api

# Public OAuth client configuration. Use Authorization Code with PKCE, no client secret.
VITE_GARGOYLE_OAUTH_CLIENT_ID=
VITE_GARGOYLE_OAUTH_AUTHORIZE_URL=/oauth/authorize
VITE_GARGOYLE_OAUTH_TOKEN_URL=/oauth/token
VITE_GARGOYLE_OAUTH_REVOKE_URL=/oauth/revoke
VITE_GARGOYLE_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/callback
VITE_GARGOYLE_OAUTH_SCOPES="read write follow push"
VITE_GARGOYLE_VAPID_PUBLIC_KEY=
